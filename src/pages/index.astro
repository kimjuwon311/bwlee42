---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Bwlee42">
  <section class="home">
    <h1>Bwlee42's Archive</h1>

    <p>
      물리와 공학에 관심이 많은 학생이<br> 생각들을 기록하는 서재입니다.<br>
      자유롭게 살펴보세요.
    </p>

    <nav class="home-links" aria-label="Main links">
      <a href="/essays">Essays</a>
      <a href="/projects">Projects</a>
      <a href="/archive">Archive</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .home {
    max-width: 820px;
    margin: 0 auto;
    padding: 13vh 1.5rem 0;
  }

  .home h1 {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
  }

  .home p {
    font-size: 1.08rem;
    line-height: 1.8;
    color: #666;
    margin: 0 0 2.5rem;
  }

  .home-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .home-links a {
    color: #666;
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s ease;
  }

  .home-links a::before {
    content: "→ ";
    color: #999;
  }

  .home-links a:hover {
    color: #222;
  }

  @media (max-width: 768px) {
    .home {
      padding-top: 8vh;
    }

    .home h1 {
      font-size: clamp(2.4rem, 9vw, 3.5rem);
    }

    .home-links {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
