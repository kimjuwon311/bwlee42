---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Bwlee42">
  <section class="home">
    <h1>Bwlee42's Archive</h1>

    <p>
      물리와 공학에 관심이 많은 학생이 생각들을 기록해두는 서재입니다.
      자유롭게 살펴보세요.
    </p>

    <div class="home-sketch" aria-hidden="true">
      <svg viewBox="0 0 260 90">
        <line x1="20" y1="45" x2="95" y2="45" />
        <path d="M95 45 Q130 10 165 45" />
        <path d="M95 45 Q130 80 165 45" />
        <line x1="165" y1="45" x2="240" y2="45" />
        <circle cx="95" cy="45" r="3" />
        <circle cx="165" cy="45" r="3" />
      </svg>
    </div>

    <nav class="home-links" aria-label="Main links">
      <a href="/essays">Essays 보러가기</a>
      <a href="/projects">Projects 살펴보기</a>
      <a href="/about">About 읽기</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .home {
    max-width: 820px;
    margin: 0 auto;
    padding: 13vh 1.5rem 0;
  }

  .home h1 {
    font-size: clamp(3.2rem, 7vw, 5.2rem);
    line-height: 1.05;
    margin: 0 0 1.4rem;
    letter-spacing: -0.04em;
  }

  .home p {
    font-size: 1.08rem;
    line-height: 1.8;
    color: #666;
    margin: 0;
    white-space: nowrap;
  }

  .home-sketch {
    width: 170px;
    margin: 2.2rem 0 2rem;
    color: #999;
  }

  .home-sketch svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .home-sketch line,
  .home-sketch path,
  .home-sketch circle {
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .home-links {
    display: flex;
    gap: 1.3rem;
    flex-wrap: wrap;
  }

  .home-links a {
    color: #555;
    text-decoration: none;
    font-size: 1rem;
  }

  .home-links a::before {
    content: "→ ";
    color: #999;
  }

  .home-links a:hover {
    color: #222;
  }

  @media (max-width: 760px) {
    .home {
      padding-top: 12vh;
    }

    .home p {
      white-space: normal;
    }
  }
</style>
