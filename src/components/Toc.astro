---
const { headings = [] } = Astro.props;
const visibleHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{visibleHeadings.length > 0 && (
  <aside class="toc">
    <strong>목차</strong>
    <ol>
      {visibleHeadings.map((heading) => (
        <li>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}
